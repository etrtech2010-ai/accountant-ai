generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTH & ORGANIZATION
// ============================================

model Firm {
  id        String   @id @default(cuid())
  name      String
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  clients          Client[]
  documents        Document[]
  categories       Category[]
  bankTransactions BankTransaction[]

  @@map("firms")
}

enum Plan {
  FREE
  PRO
  FIRM
  ENTERPRISE
}

model User {
  id        String   @id @default(cuid())
  authId    String   @unique // Supabase auth.users.id
  email     String   @unique
  name      String?
  role      Role     @default(MEMBER)
  firmId    String
  createdAt DateTime @default(now())

  firm      Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  documents Document[]      @relation("UploadedBy")
  approvals ExtractedItem[] @relation("ApprovedBy")

  @@index([firmId])
  @@map("users")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

// ============================================
// CLIENTS (the firm's clients, not app users)
// ============================================

model Client {
  id              String   @id @default(cuid())
  firmId          String
  name            String
  email           String?
  defaultCategory String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  firm             Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  documents        Document[]
  items            ExtractedItem[]
  bankTransactions BankTransaction[]

  @@index([firmId])
  @@map("clients")
}

// ============================================
// DOCUMENTS & EXTRACTION
// ============================================

model Document {
  id            String         @id @default(cuid())
  firmId        String
  clientId      String?
  uploadedById  String
  fileName      String
  fileUrl       String
  fileType      String
  fileSizeBytes Int
  status        DocumentStatus @default(PROCESSING)
  ocrRawOutput  Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  firm       Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client     Client?         @relation(fields: [clientId], references: [id])
  uploadedBy User            @relation("UploadedBy", fields: [uploadedById], references: [id])
  items      ExtractedItem[]

  @@index([firmId])
  @@index([clientId])
  @@index([status])
  @@map("documents")
}

enum DocumentStatus {
  PROCESSING
  NEEDS_REVIEW
  APPROVED
  FAILED
}

model ExtractedItem {
  id           String     @id @default(cuid())
  documentId   String
  clientId     String?
  vendor       String?
  description  String?
  amount       Decimal    @db.Decimal(12, 2)
  taxAmount    Decimal?   @db.Decimal(12, 2)
  currency     String     @default("USD")
  date         DateTime?
  categoryId   String?
  aiCategoryId String?
  confidence   Float?
  status       ItemStatus @default(PENDING)
  approvedById String?
  approvedAt   DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  document             Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  client               Client?          @relation(fields: [clientId], references: [id])
  category             Category?        @relation("AssignedCategory", fields: [categoryId], references: [id])
  aiCategory           Category?        @relation("AiSuggestedCategory", fields: [aiCategoryId], references: [id])
  approvedBy           User?            @relation("ApprovedBy", fields: [approvedById], references: [id])
  matchedTransaction   BankTransaction?

  @@index([documentId])
  @@index([status])
  @@index([clientId])
  @@map("extracted_items")
}

// ============================================
// BANK STATEMENT RECONCILIATION
// ============================================

model BankTransaction {
  id            String   @id @default(cuid())
  firmId        String
  clientId      String?
  date          DateTime
  description   String
  amount        Decimal  @db.Decimal(10, 2)
  type          String   // DEBIT or CREDIT
  balance       Float?
  status        String   @default("UNMATCHED") // UNMATCHED, MATCHED, IGNORED
  matchedItemId String?  @unique
  uploadedAt    DateTime @default(now())

  firm        Firm           @relation(fields: [firmId], references: [id])
  client      Client?        @relation(fields: [clientId], references: [id])
  matchedItem ExtractedItem? @relation(fields: [matchedItemId], references: [id])

  @@index([firmId])
  @@index([status])
  @@index([clientId])
  @@map("bank_transactions")
}

enum ItemStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

// ============================================
// CATEGORIES (Chart of Accounts aligned)
// ============================================

model Category {
  id       String  @id @default(cuid())
  firmId   String
  name     String
  code     String?
  parentId String?
  isSystem Boolean @default(false)

  firm     Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  parent   Category?       @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]      @relation("CategoryTree")
  items    ExtractedItem[] @relation("AssignedCategory")
  aiItems  ExtractedItem[] @relation("AiSuggestedCategory")

  @@unique([firmId, name])
  @@index([firmId])
  @@map("categories")
}
